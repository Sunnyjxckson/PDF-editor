{
  "name": "ai-pdf-editor",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && ./venv/bin/uvicorn main:app --reload --port 8000"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
